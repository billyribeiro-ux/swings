{
	"uid": "swings-admin-overview",
	"title": "Swings · Admin Platform Overview",
	"tags": ["swings", "admin", "platform"],
	"schemaVersion": 38,
	"version": 1,
	"editable": true,
	"timezone": "browser",
	"refresh": "30s",
	"time": { "from": "now-6h", "to": "now" },
	"templating": {
		"list": [
			{
				"name": "datasource",
				"type": "datasource",
				"query": "prometheus",
				"current": { "selected": false, "text": "Prometheus", "value": "Prometheus" }
			}
		]
	},
	"panels": [
		{
			"id": 1,
			"type": "row",
			"title": "DSAR — async export worker",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
			"collapsed": false
		},
		{
			"id": 2,
			"type": "stat",
			"title": "Exports claimed (last 1h)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
			"targets": [
				{
					"expr": "sum(increase(dsar_export_claimed_total[1h]))",
					"refId": "A"
				}
			],
			"fieldConfig": { "defaults": { "unit": "short" } }
		},
		{
			"id": 3,
			"type": "stat",
			"title": "Exports completed (last 1h)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
			"targets": [{ "expr": "sum(increase(dsar_export_completed_total[1h]))", "refId": "A" }],
			"fieldConfig": { "defaults": { "unit": "short" } }
		},
		{
			"id": 4,
			"type": "stat",
			"title": "Exports failed (last 1h)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
			"targets": [
				{
					"expr": "sum(increase(dsar_export_failed_total[1h]))",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 1 },
							{ "color": "red", "value": 5 }
						]
					},
					"color": { "mode": "thresholds" }
				}
			}
		},
		{
			"id": 5,
			"type": "stat",
			"title": "Sweep last success (age)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
			"targets": [
				{
					"expr": "time() - max(dsar_artifacts_sweep_last_success_unixtime)",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 3600 },
							{ "color": "red", "value": 7200 }
						]
					},
					"color": { "mode": "thresholds" }
				}
			}
		},
		{
			"id": 6,
			"type": "timeseries",
			"title": "DSAR export duration p95 / p99 (s)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by (le) (rate(dsar_export_duration_seconds_bucket[5m])))",
					"legendFormat": "p95",
					"refId": "A"
				},
				{
					"expr": "histogram_quantile(0.99, sum by (le) (rate(dsar_export_duration_seconds_bucket[5m])))",
					"legendFormat": "p99",
					"refId": "B"
				}
			],
			"fieldConfig": { "defaults": { "unit": "s" } }
		},
		{
			"id": 7,
			"type": "timeseries",
			"title": "DSAR sweep — artefacts removed/sec",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
			"targets": [
				{
					"expr": "sum(rate(dsar_artifacts_swept_total[5m]))",
					"legendFormat": "swept/s",
					"refId": "A"
				},
				{
					"expr": "sum(rate(dsar_artifacts_sweep_failed_total[5m])) by (stage)",
					"legendFormat": "failed/s {{stage}}",
					"refId": "B"
				}
			]
		},

		{
			"id": 10,
			"type": "row",
			"title": "Idempotency — middleware + GC",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
			"collapsed": false
		},
		{
			"id": 11,
			"type": "stat",
			"title": "idempotency_keys table rows",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
			"targets": [{ "expr": "max(idempotency_keys_table_rows)", "refId": "A" }],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 250000 },
							{ "color": "red", "value": 1000000 }
						]
					},
					"color": { "mode": "thresholds" }
				}
			}
		},
		{
			"id": 12,
			"type": "stat",
			"title": "GC last success (age)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
			"targets": [
				{
					"expr": "time() - max(idempotency_keys_prune_last_success_unixtime)",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 1800 },
							{ "color": "red", "value": 3600 }
						]
					},
					"color": { "mode": "thresholds" }
				}
			}
		},
		{
			"id": 13,
			"type": "timeseries",
			"title": "Idempotency outcomes (claims/replays/in-flight/mismatches)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
			"targets": [
				{
					"expr": "sum(rate(idempotency_claimed_total[5m]))",
					"legendFormat": "claimed",
					"refId": "A"
				},
				{
					"expr": "sum(rate(idempotency_replay_total[5m]))",
					"legendFormat": "replay",
					"refId": "B"
				},
				{
					"expr": "sum(rate(idempotency_in_flight_total[5m]))",
					"legendFormat": "in-flight 409",
					"refId": "C"
				},
				{
					"expr": "sum(rate(idempotency_mismatch_total[5m]))",
					"legendFormat": "mismatch 422",
					"refId": "D"
				},
				{
					"expr": "sum(rate(idempotency_db_error_total[5m]))",
					"legendFormat": "db error",
					"refId": "E"
				}
			]
		},
		{
			"id": 14,
			"type": "timeseries",
			"title": "Idempotency GC — pruned rows / sec",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
			"targets": [
				{
					"expr": "sum(rate(idempotency_keys_pruned_total[5m]))",
					"legendFormat": "pruned/s",
					"refId": "A"
				},
				{
					"expr": "histogram_quantile(0.95, sum by (le) (rate(idempotency_keys_prune_duration_seconds_bucket[5m])))",
					"legendFormat": "tick p95 (s)",
					"refId": "B"
				}
			]
		},

		{
			"id": 20,
			"type": "row",
			"title": "Audit retention",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
			"collapsed": false
		},
		{
			"id": 21,
			"type": "stat",
			"title": "Audit prune last success (age)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 4, "w": 6, "x": 0, "y": 27 },
			"targets": [
				{
					"expr": "time() - max(audit_prune_last_success_unixtime)",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 43200 },
							{ "color": "red", "value": 86400 }
						]
					},
					"color": { "mode": "thresholds" }
				}
			}
		},
		{
			"id": 22,
			"type": "timeseries",
			"title": "Audit pruned rows / sec",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 7, "w": 9, "x": 6, "y": 27 },
			"targets": [
				{
					"expr": "sum(rate(audit_pruned_total[5m]))",
					"legendFormat": "pruned/s",
					"refId": "A"
				}
			]
		},
		{
			"id": 23,
			"type": "timeseries",
			"title": "Audit prune duration p95",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 7, "w": 9, "x": 15, "y": 27 },
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by (le) (rate(audit_prune_duration_seconds_bucket[5m])))",
					"legendFormat": "p95",
					"refId": "A"
				}
			],
			"fieldConfig": { "defaults": { "unit": "s" } }
		},

		{
			"id": 30,
			"type": "row",
			"title": "RBAC — admin mutation rate-limit & impersonation",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
			"collapsed": false
		},
		{
			"id": 31,
			"type": "timeseries",
			"title": "admin_mutation_rate_limited_total / sec (per backend)",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 7, "w": 12, "x": 0, "y": 35 },
			"targets": [
				{
					"expr": "sum by (backend) (rate(admin_mutation_rate_limited_total[5m]))",
					"legendFormat": "{{backend}}",
					"refId": "A"
				}
			]
		},
		{
			"id": 32,
			"type": "timeseries",
			"title": "Impersonation events",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 7, "w": 12, "x": 12, "y": 35 },
			"targets": [
				{
					"expr": "sum(rate(impersonation_mint_rate_limited_total[5m]))",
					"legendFormat": "mint rate-limited/s",
					"refId": "A"
				},
				{
					"expr": "sum(rate(impersonation_revoke_total[5m]))",
					"legendFormat": "revoked/s",
					"refId": "B"
				}
			]
		},

		{
			"id": 40,
			"type": "row",
			"title": "Maintenance mode + IP allowlist",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
			"collapsed": false
		},
		{
			"id": 41,
			"type": "timeseries",
			"title": "Maintenance-mode rejections / sec",
			"datasource": { "uid": "${datasource}", "type": "prometheus" },
			"gridPos": { "h": 7, "w": 24, "x": 0, "y": 43 },
			"targets": [
				{
					"expr": "sum(rate(maintenance_mode_blocked_total[5m]))",
					"legendFormat": "blocked/s",
					"refId": "A"
				}
			]
		}
	]
}
