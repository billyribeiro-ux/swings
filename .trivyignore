# Trivy ignore patterns for filesystem scans run in CI.
#
# Scope: this file is consumed by the `.github/workflows/security.yml`
# `trivy-fs` job. Paths are patterns relative to the scanned root (the repo
# root). Directories listed here are skipped entirely — either because they
# are auto-generated, produced by builds, or covered by a different scanner
# (cargo-audit / pnpm-audit already own their respective dependency trees).

# Node / frontend build artefacts
node_modules/
.svelte-kit/
.vercel/
.netlify/
dist/
build/

# Rust build artefacts
backend/target/

# Test snapshots / fixtures (reviewed by humans, not scanned)
backend/tests/snapshots/

# Uploaded user content in dev
backend/uploads/

# Lockfiles — Trivy reads these for config scans, but they are covered
# by cargo-audit and pnpm-audit in dedicated jobs.
# (No suppression here — kept for reference.)
