# ─────────────────────────────────────────────────────────────────────────────
# Core (ALL required in production — see `Config::assert_production_ready`)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/swings
# Optional in development, required in production when auto-seeding admin
APP_ENV=development
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30
PORT=3001
FRONTEND_URL=http://localhost:5173
# Public Rust API origin. Used for Stripe success/cancel URLs and
# anything that needs to mint absolute links back to the API.
API_URL=http://localhost:3001
# Public SvelteKit app origin (may differ from FRONTEND_URL when the web
# app is deployed to a CDN / preview URL).
APP_URL=http://localhost:5173

# Comma-separated, no trailing slashes. Browsers treat apex and www as different origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Production example (both hosts if you use www in DNS):
# CORS_ALLOWED_ORIGINS=https://precisionoptionsignals.com,https://www.precisionoptionsignals.com

# ADM-08: AEAD key for `app_settings.value_type='secret'` rows. 32-byte
# base64. Generate with `openssl rand -base64 32`. REQUIRED IN PRODUCTION.
SETTINGS_ENCRYPTION_KEY=change-me-base64-32-bytes
# Optional: extra key for application-level column encryption.
# APP_DATA_KEY=change-me-base64-32-bytes

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (required in production)
# ─────────────────────────────────────────────────────────────────────────────
# Same Stripe *test* secret as repo root .env (one account). Used by webhooks, billing portal, etc.
STRIPE_SECRET_KEY=sk_test_xxx
# Local dev: run `pnpm stripe:listen`, paste the whsec_ the CLI prints, restart the API.
# Dashboard webhook secrets are for deployed URLs only.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─────────────────────────────────────────────────────────────────────────────
# Email (FDN-09 — resend is the production default)
# ─────────────────────────────────────────────────────────────────────────────
# Values: resend | smtp | noop.
# Unset defaults: `resend` in production, `smtp` in dev when SMTP_USER is
# present, otherwise `noop` (log-only, no network send).
EMAIL_PROVIDER=resend
# Required when EMAIL_PROVIDER=resend.
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx
# Optional — defaults to "Swings <noreply@precisionoptionsignals.com>".
RESEND_FROM="Swings <noreply@precisionoptionsignals.com>"
# Optional API-host override — used by staging + tests; do not set in prod.
# RESEND_API_BASE=https://api.resend.com

# SMTP fallback credentials (used when EMAIL_PROVIDER=smtp).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="Swings <noreply@precisionoptionsignals.com>"

# ─────────────────────────────────────────────────────────────────────────────
# R2 (Cloudflare) object storage (REQUIRED in production)
# ─────────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
# Override the local storage path (used by dev / when R2 is intentionally
# disabled). Created on boot if absent.
UPLOAD_DIR=./uploads

# ─────────────────────────────────────────────────────────────────────────────
# Anti-abuse / consent integrations (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile — gates public forms when set.
# TURNSTILE_SECRET=
# Akismet — marks public form submissions as spam when set.
# AKISMET_API_KEY=
# AKISMET_SITE_URL=https://example.com
# MaxMind GeoIP2 city/country DB — enables geo targeting for popups.
# MAXMIND_DB_PATH=/opt/geoip/GeoLite2-Country.mmdb
# Additional salt used when hashing IPs for audit/consent records.
# CONSENT_IP_SALT=change-me

# ─────────────────────────────────────────────────────────────────────────────
# Worker / cadence tuning (safe defaults; override only for ops reasons)
# ─────────────────────────────────────────────────────────────────────────────
# Outbox workers
# OUTBOX_WORKERS=4
# OUTBOX_BATCH_SIZE=16
# Audit-log retention sweep cadence (seconds)
# AUDIT_RETENTION_INTERVAL_SECS=3600
# DSAR async export worker cadence (seconds)
# DSAR_WORKER_INTERVAL_SECS=30
# DSAR artefact TTL sweep cadence (seconds)
# DSAR_SWEEP_INTERVAL_SECS=3600
# Idempotency cache GC cadence (seconds)
# IDEMPOTENCY_GC_INTERVAL_SECS=300
# Digital download grant TTL + quota (see `handlers/digital_delivery.rs`)
# DOWNLOAD_GRANT_TTL_HOURS=720
# DOWNLOAD_GRANT_QUOTA=5
# Attribution window for popup → conversion credit (hours)
# ATTRIBUTION_WINDOW_HOURS=24

# ─────────────────────────────────────────────────────────────────────────────
# Postgres connection pool (safe defaults for a 2-vCPU container)
# Size `PGPOOL_MAX` as `(server max_connections - other clients) / replicas`.
# ─────────────────────────────────────────────────────────────────────────────
# PGPOOL_MAX=10
# PGPOOL_MIN=0
# PGPOOL_ACQUIRE_TIMEOUT=10
# PGPOOL_IDLE_TIMEOUT=300
# PGPOOL_MAX_LIFETIME=1800

# ─────────────────────────────────────────────────────────────────────────────
# Rate limiting + observability
# ─────────────────────────────────────────────────────────────────────────────
# "postgres" (durable, default in prod) or "memory" (dev only).
# RATE_LIMIT_BACKEND=postgres
# "json" (production) or "pretty" (dev).
# LOG_FORMAT=json
